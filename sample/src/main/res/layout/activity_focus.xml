<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="10dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Focus demo"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/focus_state"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textSize="10sp" />

        <EditText
            android:id="@+id/text_box"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textSize="12sp"
            android:hint="Move focus here with the D-pad"
            android:inputType="text" />

        <Button
            android:id="@+id/btn_other"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="34dp"
            android:layout_marginTop="6dp"
            android:padding="6dp"
            android:textSize="11sp"
            android:background="@drawable/focus_button"
            android:text="A plain button (move focus here)" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textSize="9sp"
            android:text="Outside the text box: LEFT = Options (the app-wide default key) and RIGHT = Back. Move focus INTO the text box and the softkeys become Clear / Done — the labels on the bar and the toasts change with focus." />
    </LinearLayout>
</ScrollView>
