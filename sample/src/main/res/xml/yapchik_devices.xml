<?xml version="1.0" encoding="utf-8"?>
<!--
    Key mappings and per-device settings for the softkey library, loaded in
    App.kt with Yapchik.loadDeviceProfiles(this, R.xml.yapchik_devices).

    <softkeys>  Extra keycodes appended to the built-in "All known softkeys"
                profile — for vendor softkeys the library doesn't know about.
                Names (KEYCODE_ prefix optional) or raw numbers, comma
                separated. Reserved keys (D-pad, numbers, letters, volume…)
                are ignored, and BACK is not accepted here because it has a
                system meaning; declare it per device instead.

    <device>    Matched case-insensitively against android.os.Build.MODEL
                (Settings > About phone > Model, or
                `adb shell getprop ro.product.model`).
                  left / right  — replace the key mapping on that device
                                  (BACK is allowed here)
                  navGuardDp    — extra bar height used on framework themes
                                  (Theme.DeviceDefault) while the navbar is
                                  hidden, keeping the labels above vendor
                                  strips that survive the hide:
                                  "none" = no guard, or an integer in dp

    Precedence: the user's own choice (chooser / calibration) beats a
    <device> entry, which beats the <softkeys> list.
-->
<devices>

    <softkeys
        left="SOFT_LEFT,MENU,F1"
        right="SOFT_RIGHT,F2" />

    <!-- Examples — replace with real models:
    <device model="SL006D" left="SOFT_LEFT" right="SOFT_RIGHT" navGuardDp="16" />
    <device model="XP3800" left="139" right="140" />
    <device model="SOME-CLEAN-PHONE" navGuardDp="none" />
    -->

</devices>
